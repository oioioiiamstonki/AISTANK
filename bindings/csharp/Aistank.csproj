<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <InvariantGlobalization>true</InvariantGlobalization>
    <RootNamespace>Aistank</RootNamespace>
    <!-- Native DLL is produced by the CMake build; copy alongside the exe. -->
    <AistankNativeDir>..\..\build\Release</AistankNativeDir>
  </PropertyGroup>

  <ItemGroup Condition="Exists('$(AistankNativeDir)\aistank.dll')">
    <None Include="$(AistankNativeDir)\aistank.dll" CopyToOutputDirectory="PreserveNewest" />
    <None Include="$(AistankNativeDir)\mujoco.dll" CopyToOutputDirectory="PreserveNewest"
          Condition="Exists('$(AistankNativeDir)\mujoco.dll')" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\assets\**" LinkBase="assets" CopyToOutputDirectory="PreserveNewest" />
    <None Include="..\..\shaders\*.cso" LinkBase="shaders" CopyToOutputDirectory="PreserveNewest"
          Condition="Exists('..\..\shaders')" />
  </ItemGroup>
</Project>
